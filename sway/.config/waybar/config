{
    "layer": "top",
    "position": "top",
    "modules-left": ["sway/workspaces", "sway/mode"],
    "modules-center": ["clock"],
    "modules-right": ["pulseaudio", "battery", "tray"],
    "sway/workspaces": {
        "disable-scroll": true
    },
    "clock": {
        "format": "{:%Y-%m-%d %H:%M:%S}",
        "interval": 1
    },
    "pulseaudio": {
        "format": "VOL {volume}%",
        "format-muted": "MUTED",
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle"
    },
    "battery": {
        "format": "{status} {capacity}%",
        "states": {
            "warning": 30,
            "critical": 10
        }
    },
    "tray": {
        "spacing": 10
    }
}
