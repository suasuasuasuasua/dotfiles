// niri config

input {
    keyboard {
        xkb { }
    }

    touchpad {
        tap
        natural-scroll
    }
}

// Set scale for HiDPI — run `niri msg outputs` to find your output name
output "eDP-1" {
    scale 1.5
}

layout {
    gaps 8

    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
    }

    default-column-width { proportion 0.5; }

    focus-ring {
        width 2
        active-color "#7aa2f7"
        inactive-color "#565f89"
    }

    border {
        off
        width 4
        active-color "#ffc87f"
        inactive-color "#505050"
        urgent-color "#9b0000"
    }
}

spawn-at-startup "nm-applet" "--indicator"
spawn-at-startup "swayidle" "-w" "timeout" "300" "swaylock -f" "before-sleep" "swaylock -f"

screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"

binds {
    // shows a list of important hotkeys.
    Alt+Shift+Slash { show-hotkey-overlay; }

    // Terminal
    Alt+Return hotkey-overlay-title="Open a Terminal: alacritty" { spawn "alacritty"; }
    // Alt+D hotkey-overlay-title="Run an Application: wofi" { spawn "wofi" "--show" "drun"; }
    Super+Alt+L hotkey-overlay-title="Lock the Screen: swaylock" { spawn "swaylock"; }

    // Spotlight
    Alt+Space { spawn "dms" "ipc" "call" "spotlight" "toggle"; }

    // Open/close the Overview: a zoomed-out view of workspaces and windows.
    Alt+O repeat=false { toggle-overview; }
    // Kill window
    Alt+Shift+Q { close-window; }

    // Focus
    Alt+H { focus-column-left; }
    Alt+L { focus-column-right; }
    Alt+J { focus-window-down; }
    Alt+K { focus-window-up; }

    // Move windows
    Alt+Shift+H { move-column-left; }
    Alt+Shift+L { move-column-right; }
    Alt+Shift+J { move-window-down; }
    Alt+Shift+K { move-window-up; }

    // Column width
    Alt+R { switch-preset-column-width; }
    Alt+F { maximize-column; }
    Alt+Shift+F { fullscreen-window; }

    // Group windows into a column (niri's equivalent of splits)
    Alt+B { consume-window-into-column; }
    Alt+V { expel-window-from-column; }

    // Workspaces
    Alt+1 { focus-workspace 1; }
    Alt+2 { focus-workspace 2; }
    Alt+3 { focus-workspace 3; }
    Alt+4 { focus-workspace 4; }
    Alt+5 { focus-workspace 5; }
    Alt+6 { focus-workspace 6; }
    Alt+7 { focus-workspace 7; }
    Alt+8 { focus-workspace 8; }
    Alt+9 { focus-workspace 9; }

    Alt+Shift+1 { move-window-to-workspace 1; }
    Alt+Shift+2 { move-window-to-workspace 2; }
    Alt+Shift+3 { move-window-to-workspace 3; }
    Alt+Shift+4 { move-window-to-workspace 4; }
    Alt+Shift+5 { move-window-to-workspace 5; }
    Alt+Shift+6 { move-window-to-workspace 6; }
    Alt+Shift+7 { move-window-to-workspace 7; }
    Alt+Shift+8 { move-window-to-workspace 8; }
    Alt+Shift+9 { move-window-to-workspace 9; }

    // niri control
    Alt+Shift+E { quit; }

    // stack tabs
    Alt+W { toggle-column-tabbed-display; }

    // Volume
    XF86AudioRaiseVolume allow-when-locked=true { spawn "pactl" "set-sink-volume" "@DEFAULT_SINK@" "+10%"; }
    XF86AudioLowerVolume allow-when-locked=true { spawn "pactl" "set-sink-volume" "@DEFAULT_SINK@" "-10%"; }
    XF86AudioMute        allow-when-locked=true { spawn "pactl" "set-sink-mute" "@DEFAULT_SINK@" "toggle"; }
    XF86AudioMicMute     allow-when-locked=true { spawn "pactl" "set-source-mute" "@DEFAULT_SOURCE@" "toggle"; }

    XF86AudioPlay        allow-when-locked=true { spawn-sh "playerctl play-pause"; }
    XF86AudioStop        allow-when-locked=true { spawn-sh "playerctl stop"; }
    XF86AudioPrev        allow-when-locked=true { spawn-sh "playerctl previous"; }
    XF86AudioNext        allow-when-locked=true { spawn-sh "playerctl next"; }

    XF86MonBrightnessUp allow-when-locked=true { spawn "brightnessctl" "--class=backlight" "set" "+10%"; }
    XF86MonBrightnessDown allow-when-locked=true { spawn "brightnessctl" "--class=backlight" "set" "10%-"; }

    // Screenshots
    Print       { screenshot; }
    Shift+Print { screenshot-screen; }
    Alt+Print   { screenshot-window; }
}
