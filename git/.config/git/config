[core]
    editor = nvim
[user]
    name = Justin Hoang
    email = justinhoang@sua.dev
    signingkey = justinhoang@sua.dev
[init]
    defaultBranch = main
[pull]
    rebase = false
[push]
    autoSetupRemote = true
[commit]
    gpgsign = true
[diff]
    tool = vimdiff
    algorithm = patience
[difftool]
    prompt = false
[difftool "vimdiff"]
    layout = LOCAL,REMOTE
[difftool "nvim_difftool"]
    cmd = nvim -c \"packadd nvim.difftool\" -d \"$LOCAL\" \"$REMOTE\"
[merge]
    tool = vimdiff
    conflictStyle = zdiff3
[mergetool]
    prompt = false
    keepBackup = false
[mergetool "vimdiff"]
    cmd = vim -f -d -c \"wincmd J\" \"$MERGED\" \"$LOCAL\" \"$BASE\" \"$REMOTE\"
    layout = LOCAL,BASE,REMOTE / MERGED
