[core]
    editor = nvim
    autocrlf = input
[user]
    name = Justin Hoang
    email = justinhoang@sua.dev
    signingkey = justinhoang@sua.dev
[init]
    defaultBranch = main
[fetch]
    prune = true
    pruneTags = true
[pull]
    rebase = true
    ff = only
[push]
    autoSetupRemote = true
[rebase]
    autoStash = true
    autoSquash = true
    updateRefs = true
[rerere]
    enabled = true # remember conflict resolutions
[commit]
    gpgsign = true
    verbose = true
[diff]
    colorMoved = zebra
    mnemonicPrefix = true
    renames = copies
    tool = vimdiff
    algorithm = patience
[difftool]
    prompt = false
    trustExitCode = true
[difftool "vimdiff"]
    cmd = vim -d -f \"$LOCAL\" \"$REMOTE\"
[difftool "nvim_difftool"]
    cmd = nvim -c \"packadd nvim.difftool\" -d \"$LOCAL\" \"$REMOTE\"
[merge]
    tool = vimdiff
    conflictStyle = zdiff3
    trustExitCode = true
[mergetool]
    prompt = false
    keepBackup = false
[mergetool "vimdiff"]
    cmd = vim -f -d -c \"wincmd J\" \"$MERGED\" \"$LOCAL\" \"$BASE\" \"$REMOTE\"
    layout = LOCAL,BASE,REMOTE / MERGED
[mergetool "nvim_mergetool"]
    cmd = nvim -f -d -c \"wincmd J\" \"$MERGED\" \"$LOCAL\" \"$BASE\" \"$REMOTE\"
    layout = LOCAL,BASE,REMOTE / MERGED
